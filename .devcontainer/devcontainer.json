{
  // Replace REPO_NAME with the repository name in:
  //   - "name", "runArgs" --name, "workspaceMount", "workspaceFolder", and volume source names.
  "name": "REPO_NAME",
  "runArgs": [
    "--name",
    "REPO_NAME"
  ],
  "build": {
    "dockerfile": "Dockerfile"
  },
  "remoteUser": "vscode",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/REPO_NAME,type=bind,consistency=cached",
  "workspaceFolder": "/workspaces/REPO_NAME",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "mounts": [
    {
      "source": "REPO_NAME-claude",
      "target": "/home/vscode/.claude",
      "type": "volume"
    },
    {
      "source": "REPO_NAME-codex",
      "target": "/home/vscode/.codex",
      "type": "volume"
    }
  ],
  "postStartCommand": "sudo chown -R vscode:vscode /home/vscode/.claude /home/vscode/.codex && sudo chmod -R a+rwX /home/vscode/.vscode-server",
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postAttachCommand": "bash .devcontainer/post-attach.sh",
  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/home/vscode/.claude",
    "CODEX_HOME": "/home/vscode/.codex",
    "XDG_CACHE_HOME": "/tmp/xdg-cache",
    "XDG_DATA_HOME": "/tmp/xdg-data"
  },
  "remoteEnv": {
    "CLAUDE_CONFIG_DIR": "/home/vscode/.claude",
    "CODEX_HOME": "/home/vscode/.codex",
    "XDG_CACHE_HOME": "/tmp/xdg-cache",
    "XDG_DATA_HOME": "/tmp/xdg-data"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "bierner.markdown-mermaid",
        "bierner.markdown-preview-github-styles",
        "clevermonkey.claude-monkey-bar",
        "codezombiech.gitignore",
        "davidanson.vscode-markdownlint",
        "eamodio.gitlens",
        "editorconfig.editorconfig",
        "foxundermoon.shell-format",
        "github.vscode-github-actions",
        "github.vscode-pull-request-github",
        "gruntfuggly.todo-tree",
        "jasonnutter.vscode-codeowners",
        "ms-azuretools.vscode-containers",
        "ms-azuretools.vscode-docker",
        "openai.chatgpt",
        "pflannery.vscode-versionlens",
        "pkief.material-icon-theme",
        "redhat.vscode-xml",
        "redhat.vscode-yaml",
        "sidneys1.gitconfig",
        "tamasfe.even-better-toml",
        "wdhongtw.gpg-indicator",
        "wekex.jsonlint",
        "yzhang.markdown-all-in-one"
      ],
      "settings": {
        "files.eol": "\n"
      }
    }
  }
}
